<?xml version="1.0" encoding="utf-8"?>
<!-- Track outline ring: keeps the OFF switch clearly visible against the dark
     dialog surface (a light-grey ring), and matches the accent when ON. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="@color/primary" android:state_checked="true" />
    <item android:color="@color/on_surface_variant" />
</selector>
