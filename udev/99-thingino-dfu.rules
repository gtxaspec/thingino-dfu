# Thingino DFU / cloner - USB access rules
#
# Grants non-root users (and WebUSB in Chrome/Edge) raw access to Ingenic SoCs
# in every USB state they pass through while flashing:
#   - bootrom         a108:c309  (T31/T32/T33/T40/T41/A1)   601a:4770 (T10/T20/T21/T23/T30)
#   - firmware stage  a108:8887
#   - U-Boot DFU      a108:4d44  ("USB download gadget")
#
# Without this, requestDevice() in the browser can still enumerate the device
# but USBDevice.open() fails with "SecurityError: Access denied", and the
# native tool reports "access denied".
#
# Install (on the machine the device is plugged into):
#   sudo cp 99-thingino-dfu.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
# Then unplug and replug the device.

# Ingenic primary VID: bootrom (c309), firmware (8887), U-Boot DFU gadget (4d44)
SUBSYSTEM=="usb", ATTR{idVendor}=="a108", MODE="0666", TAG+="uaccess"

# Ingenic alternate VID: older-SoC bootrom (e.g. 601a:4770)
SUBSYSTEM=="usb", ATTR{idVendor}=="601a", MODE="0666", TAG+="uaccess"
